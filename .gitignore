# --- Python Environment ---
# Αγνοεί τον φάκελο του virtual environment
venv/
.venv/
env/
bin/
lib/
include/

# --- Python Caches ---
# Αγνοεί τα προσωρινά αρχεία που δημιουργεί η Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ipynb_checkpoints/

# --- Environment Variables ---
# ΠΟΛΥ ΣΗΜΑΝΤΙΚΟ: Αγνοεί το αρχείο με το API KEY σου
.env

# --- Streamlit ---
# Αγνοεί τα logs και τα configs του Streamlit
.streamlit/

# --- Operating System ---
# Αγνοεί αρχεία συστήματος (Mac/Windows)
.DS_Store
Thumbs.db

# --- Docker ---
# Αγνοεί τα logs του Docker
.dockerignore